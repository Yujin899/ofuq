rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is a member or owner of a specific workspace
    function isWorkspaceMember(workspaceId) {
      let workspace = get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
      return isAuthenticated() && (
        request.auth.uid == workspace.ownerId || 
        request.auth.uid in workspace.memberIds
      );
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // --- Workspaces ---
    match /workspaces/{workspaceId} {
      // Allow read for join verification. Sub-collections are independently protected.
      allow read: if isAuthenticated();
      
      // Only owner can create or delete
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;

      // Allow owner full write, allow others ONLY to add themselves to memberIds
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerId ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
          request.auth.uid in request.resource.data.memberIds &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds)
        )
      );

      // --- Journeys & Progress ---
      match /journeys/{journeyId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceMember(workspaceId); 
        
        match /user_progress/{userId} {
          allow read: if isAuthenticated(); // Members see each other for Trail avatars
          allow write: if isOwner(userId);
        }
      }

      // --- Sessions (Study Data) ---
      match /sessions/{sessionId} {
        allow read: if isAuthenticated(); // For Leaderboard metrics
        
        // FIXED: Split write into create and update/delete
        // Using "resource.exists" inside a single rule crashes evaluation when creating.
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
        allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      }

      // --- Subjects & Lectures ---
      match /subjects/{subjectId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceMember(workspaceId);
        
        match /lectures/{lectureId} {
          allow read: if isWorkspaceMember(workspaceId);
          allow write: if isWorkspaceMember(workspaceId);
        }
      }
    }

    // --- Global Templates ---
    match /core_subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }
  }
}
